{
   "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
   "JwtSettings": {
    "Authority": "http://localhost:8001",
    "Audience": "his-platform-api"
  },

  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/identity/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ]
      },
      "core-route": {
        "ClusterId": "core-cluster",
        "Match": { "Path": "/api/core/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ]
      }
    },

    "Clusters": {
      "identity-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "Destinations": {
          "d1": { "Address": "http://localhost:8001/" }
        }
      },

      "core-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "HttpRequest": {
          "Version": "1.1",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "Destinations": {
          "d1": { "Address": "http://localhost:8003/" }
        }
      }
    }
  }
}